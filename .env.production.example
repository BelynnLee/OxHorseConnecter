# Remote Agent Console - Production Environment Template
#
# Copy this file to the repository-root .env on the production host and replace
# every <PLACEHOLDER> with a real value. Values marked REQUIRED must be set;
# Host will refuse to start if they fail validation.
#
# Generate strong secrets (Linux/macOS):
#   openssl rand -hex 32
# On Windows PowerShell:
#   -join ((48..57) + (97..122) | Get-Random -Count 64 | ForEach-Object {[char]$_})

# ---------- Runtime mode (REQUIRED) ----------
NODE_ENV=production
REQUIRE_HTTPS=true
TRUST_PROXY=true

# ---------- Network (REQUIRED) ----------
HOST_PORT=3001
# Bind to loopback only — TLS is terminated by the reverse proxy
HOST_HOSTNAME=127.0.0.1
# Public-facing URL announced to the browser; must be HTTPS in strict mode
PUBLIC_BASE_URL=https://console.example.com
# Restrict CORS to the trusted public origin
CORS_ORIGINS=https://console.example.com

# ---------- Security profile (REQUIRED) ----------
# Strict mode enforces:
#   - HTTPS for PUBLIC_BASE_URL
#   - High-risk shell command refusal
#   - Rejection of CODEX_FULL_AUTO=true and CLAUDE_CODE_SKIP_PERMISSIONS=true
AGENT_SECURITY_PROFILE=strict

# ---------- Authentication (REQUIRED — replace ALL placeholders) ----------
ADMIN_USERNAME=admin
# Minimum 12 characters in strict mode
ADMIN_PASSWORD=<CHANGE_ME_to_strong_random_password_12_or_more_chars>
# Minimum 32 characters
JWT_SECRET=<CHANGE_ME_to_64_char_random_hex_string>
ACCESS_TOKEN_TTL_SECONDS=43200
AUTH_COOKIE_NAME=rac_access_token
# REQUIRED: must be true when serving over HTTPS
AUTH_COOKIE_SECURE=true
AUTH_COOKIE_SAME_SITE=lax
# REQUIRED: must be false in production to prevent token leakage in URLs
ALLOW_QUERY_TOKEN_AUTH=false
LOGIN_RATE_LIMIT_MAX_ATTEMPTS=5
LOGIN_RATE_LIMIT_WINDOW_SECONDS=60
LOGIN_RATE_LIMIT_LOCKOUT_SECONDS=300
LOGIN_RATE_LIMIT_EXEMPT_LOOPBACK=false

# ---------- Storage (REQUIRED) ----------
# Use absolute path or path relative to Host working directory
DB_PATH=./data/rac.db
# Restrict where tasks/sessions can write — prevents path traversal
ALLOWED_WORK_DIR=./data/workspaces
# On remote worker machines, set this to the worker-local controlled workspace.
# If unset, the remote worker falls back to ALLOWED_WORK_DIR.
# RAC_REMOTE_ALLOWED_WORK_DIR=/srv/rac-worker/workspaces
# Remote worker heartbeat, bridge ping, and reconnect tuning.
RAC_REMOTE_HEARTBEAT_INTERVAL_MS=3000
RAC_REMOTE_MAX_RECONNECT_DELAY_MS=30000
RAC_REMOTE_BRIDGE_PING_INTERVAL_MS=15000

# ---------- Provider secrets (REQUIRED) ----------
# Encrypts API keys saved in the provider config table
PROVIDER_SECRET_KEY=<CHANGE_ME_to_64_char_random_hex_string>
# Required for HTTPS-deployed remote workers to register
REMOTE_REGISTRATION_TOKEN=<CHANGE_ME_to_64_char_random_hex_string>

# ---------- Task safety ----------
APPROVAL_TIMEOUT_SECONDS=120
TASK_MAX_DURATION_SECONDS=1800
LOG_REDACTION_ENABLED=true
# RISK_RULES_PATH=/etc/rac/risk-rules.json

# ---------- Logging ----------
# Forward stdout/stderr to a log file (rotation handled by Host on date roll)
# LOG_FILE_PATH=./data/logs/rac-host.log
# LOG_FILE_KEEP_DAYS=30

# ---------- Web console build-time variables ----------
# These must be set BEFORE running pnpm build:web — they bake into the bundle
VITE_API_URL=https://console.example.com
VITE_SSE_URL=https://console.example.com/api/stream
VITE_WS_URL=wss://console.example.com

# ---------- Executors ----------
CLAUDE_CODE_ENABLED=true
CLAUDE_CODE_COMMAND=claude
CLAUDE_CODE_MODEL=claude-sonnet-4-6
CLAUDE_CODE_MAX_TURNS=30
# REQUIRED: must be false in strict mode
CLAUDE_CODE_SKIP_PERMISSIONS=false

CODEX_ENABLED=true
CODEX_COMMAND=codex
CODEX_MODEL=o3
# REQUIRED: must be false in strict mode
CODEX_FULL_AUTO=false

# ---------- Optional notifications ----------
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=
# TELEGRAM_WEBHOOK_SECRET=
# WEBHOOK_URL=
# WEBHOOK_SECRET=
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=

# ---------- Optional Telegram Agent Gateway ----------
TELEGRAM_GATEWAY_ENABLED=false
TELEGRAM_MODE=webhook
# TELEGRAM_WEBHOOK_URL=https://console.example.com/api/telegram/webhook
# TELEGRAM_ALLOWED_USERS=123456789,alice
TELEGRAM_ALLOW_ALL_USERS=false
# TELEGRAM_GROUP_ALLOWED_CHATS=-1001234567890
TELEGRAM_REQUIRE_MENTION=true
TELEGRAM_DEFAULT_DEVICE_ID=host
# TELEGRAM_DEFAULT_PROJECT_ID=
# TELEGRAM_DEFAULT_PROJECT_PATH=
TELEGRAM_DEFAULT_EXECUTOR=codex
TELEGRAM_DEFAULT_MODE=agent
TELEGRAM_DEFAULT_PERMISSION_MODE=default
TELEGRAM_STREAMING_ENABLED=false

# ---------- Optional AI service ----------
# Enable only when RAG indexing or evaluation helpers are required
# AI_SERVICE_URL=http://127.0.0.1:8010
