# Remote Agent Console / Agent Workbench environment example
#
# Copy this file to the repository-root .env for local development.
# Do not commit real secrets.

# Host service
NODE_ENV=development
HOST_PORT=3001
HOST_HOSTNAME=127.0.0.1
PUBLIC_BASE_URL=http://127.0.0.1:3001
HOST_DEVICE_NAME=local-dev-machine
HOST_DEVICE_PLATFORM=windows
# HOST_DEVICE_FINGERPRINT=local-dev-machine:windows:custom

# Local development TLS/cookie posture
REQUIRE_HTTPS=false
TRUST_PROXY=false
CORS_ORIGINS=http://127.0.0.1:5173,http://localhost:5173

# Auth
ADMIN_USERNAME=admin
ADMIN_PASSWORD=replace-with-a-strong-admin-password
JWT_SECRET=replace-with-at-least-32-random-characters
ACCESS_TOKEN_TTL_SECONDS=43200
AUTH_COOKIE_NAME=rac_access_token
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAME_SITE=lax
ALLOW_QUERY_TOKEN_AUTH=false
LOGIN_RATE_LIMIT_MAX_ATTEMPTS=5
LOGIN_RATE_LIMIT_WINDOW_SECONDS=60
LOGIN_RATE_LIMIT_LOCKOUT_SECONDS=300
LOGIN_RATE_LIMIT_EXEMPT_LOOPBACK=true

# SQLite persistence
DB_PATH=./data/rac.db

# Workspace boundary
# Restrict task/session working directories to this tree when set.
ALLOWED_WORK_DIR=./data/workspaces

# Safety and redaction
AGENT_SECURITY_PROFILE=local
REMOTE_REGISTRATION_TOKEN=
PROVIDER_SECRET_KEY=replace-with-at-least-32-random-characters
APPROVAL_TIMEOUT_SECONDS=120
TASK_MAX_DURATION_SECONDS=1800
LOG_REDACTION_ENABLED=true
LOG_LEVEL=info
# LOG_FORMAT=json
# LOG_PRETTY=true
RISK_RULES_PATH=
LOG_FILE_PATH=
LOG_FILE_KEEP_DAYS=30

# Web console
VITE_API_URL=http://127.0.0.1:3001
VITE_SSE_URL=http://127.0.0.1:3001/api/stream
VITE_WS_URL=ws://127.0.0.1:3001

# Claude Code executor (local claude CLI)
# CLAUDE_CODE_COMMAND accepts either a command on PATH or an absolute CLI path.
CLAUDE_CODE_ENABLED=true
CLAUDE_CODE_COMMAND=claude
CLAUDE_CODE_MODEL=claude-sonnet-4-6
CLAUDE_CODE_MAX_TURNS=30
# Dangerous developer-only switch. Keep false unless using a trusted disposable worktree.
CLAUDE_CODE_SKIP_PERMISSIONS=false
# Optional secret used by the claude CLI subprocess. Do not put a real key in this example.
# ANTHROPIC_API_KEY=

# Claude API executor (uses @anthropic-ai/sdk, separate from Claude Code CLI)
# CLAUDE_API_KEY=
# CLAUDE_MODEL=claude-sonnet-4-6
# CLAUDE_MAX_TOKENS=8192
# CLAUDE_MAX_TOOL_ROUNDS=30

# Codex executor (local codex CLI)
CODEX_ENABLED=true
CODEX_COMMAND=codex
CODEX_MODEL=o3
# CODEX_HOME=
# CODEX_CONFIG_FILE=
# In AGENT_SECURITY_PROFILE=strict, this must remain false.
CODEX_FULL_AUTO=false
# Optional secret used by Codex when needed. Do not put a real key in this example.
# OPENAI_API_KEY=
# OPENAI_BASE_URL=
# OPENAI_MODELS=

# Custom Command Agent executor
# Runs a host-configured command after explicit approval. The prompt is sent on stdin
# and also exposed as CODEAGENT_PROMPT.
CUSTOM_COMMAND_AGENT_ENABLED=false
# CUSTOM_COMMAND_AGENT_COMMAND=
# CUSTOM_COMMAND_AGENT_ARGS=
# CUSTOM_COMMAND_AGENT_TIMEOUT_SECONDS=1200

# Usage/cost display
# Example values are placeholders. Configure real internal pricing before showing cost.
# For cache-aware providers, include cache read/write rates or cost will be hidden when cache tokens are present.
# AGENT_MODEL_PRICING_JSON={"claude-sonnet-4-6":{"inputPerMillion":0,"outputPerMillion":0,"cacheReadInputPerMillion":0,"cacheCreationInputPerMillion":0,"cacheCreation5mInputPerMillion":0,"cacheCreation1hInputPerMillion":0,"currency":"USD"},"o3":{"inputPerMillion":0,"outputPerMillion":0,"currency":"USD"}}

# Optional MCP integration
# GITEA_BASE_URL=https://gitea.example.com
# GITEA_TOKEN=
# OPENROUTER_API_KEY=
# OPENROUTER_BASE_URL=
# OPENROUTER_MODELS=
# ANTHROPIC_BASE_URL=
# ANTHROPIC_MODELS=
# CLAUDE_MODELS=
# OLLAMA_BASE_URL=
# OLLAMA_API_KEY=
# OLLAMA_MODELS=

# Remote worker mode
# RAC_CONTROLLER_URL=https://console.example.com
# REMOTE_CONTROLLER_URL=https://console.example.com
# RAC_REMOTE_DEVICE_NAME=office-dev-machine
# RAC_REMOTE_DEVICE_PLATFORM=windows
# RAC_REMOTE_DEVICE_FINGERPRINT=office-dev-machine:windows:stable-id
# RAC_REMOTE_POLL_INTERVAL_MS=3000
# RAC_REMOTE_HEARTBEAT_INTERVAL_MS=3000
# RAC_REMOTE_MAX_RECONNECT_DELAY_MS=30000
# RAC_REMOTE_BRIDGE_PING_INTERVAL_MS=15000
# Controlled workspace root on the worker machine. If unset, falls back to ALLOWED_WORK_DIR.
# RAC_REMOTE_ALLOWED_WORK_DIR=./data/remote-workspaces
# Required when registering a worker against a strict/HTTPS controller.
# RAC_REMOTE_REGISTRATION_TOKEN=
# RAC_REMOTE_DEVICE_ID=
# RAC_REMOTE_DEVICE_TOKEN=

# Native provider runtime and local config locations
# CLAUDE_HOME=
# CLAUDE_SETTINGS_FILE=
# TERMINAL=
RAC_CODEX_APP_SERVER_DISABLED=false
RAC_CLAUDE_AGENT_SDK_DISABLED=false
RAC_DISABLE_CLAUDE_AGENT_SDK=false
RAC_ALLOW_UNSAFE_PROVIDER_APPROVAL_FALLBACK=false

# Notifications
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=
# TELEGRAM_WEBHOOK_SECRET=
# WEBHOOK_URL=
# WEBHOOK_SECRET=
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=

# Telegram Agent Gateway (optional; disabled by default)
TELEGRAM_GATEWAY_ENABLED=false
TELEGRAM_MODE=auto
# TELEGRAM_WEBHOOK_URL=https://console.example.com/api/telegram/webhook
# TELEGRAM_ALLOWED_USERS=123456789,alice
TELEGRAM_ALLOW_ALL_USERS=false
# TELEGRAM_GROUP_ALLOWED_CHATS=-1001234567890
TELEGRAM_REQUIRE_MENTION=true
TELEGRAM_DEFAULT_DEVICE_ID=host
# TELEGRAM_DEFAULT_PROJECT_ID=
# TELEGRAM_DEFAULT_PROJECT_PATH=
TELEGRAM_DEFAULT_EXECUTOR=codex
TELEGRAM_DEFAULT_MODE=agent
TELEGRAM_DEFAULT_PERMISSION_MODE=default
TELEGRAM_STREAMING_ENABLED=false
TELEGRAM_STREAM_EDIT_INTERVAL_MS=700
# TELEGRAM_CACHE_DIR=./data/telegram-cache
# TELEGRAM_MEDIA_MAX_BYTES=20971520

# Production baseline:
# - NODE_ENV=production
# - PUBLIC_BASE_URL=https://console.example.com
# - REQUIRE_HTTPS=true
# - TRUST_PROXY=true when behind a trusted HTTPS reverse proxy
# - AGENT_SECURITY_PROFILE=strict
# - ADMIN_PASSWORD, JWT_SECRET, PROVIDER_SECRET_KEY, and
#   REMOTE_REGISTRATION_TOKEN must be strong non-placeholder secrets.
# - CODEX_FULL_AUTO=false
# - CLAUDE_CODE_SKIP_PERMISSIONS=false
